# ---------------------------------------------------------------------------
# YCS Discord toolkit configuration
# Copy this file to `.env` and fill in the values. `.env` is gitignored so
# your secrets never get committed.
# ---------------------------------------------------------------------------

# The bot token from the Discord Developer Portal (Bot > Reset Token).
# Required for: invite links, starting discussions, and server management.
# Keep this SECRET — anyone with it controls your bot.
DISCORD_BOT_TOKEN=

# The application (client) ID from the Developer Portal > General Information.
# Required to register the bot's slash commands (npm run deploy).
DISCORD_CLIENT_ID=

# Your server's ID (right-click the server icon > Copy Server ID).
# Needs Developer Mode on: User Settings > Advanced > Developer Mode.
DISCORD_GUILD_ID=

# The default channel ID that blasts/discussions post to when you don't
# pass --channel (right-click a channel > Copy Channel ID).
DISCORD_CHANNEL_ID=

# --- Stable "never-dies" Discord link -------------------------------------
# The bot mints a fresh invite behind a stable URL (yourhost/discord) and keeps
# it alive, so the link you put in Kit never changes or breaks.
# Channel the invite points at — use one every new member can see (e.g. #welcome
# or your rules channel). Falls back to DISCORD_CHANNEL_ID if blank.
DISCORD_INVITE_CHANNEL_ID=

# How often (in hours) to refresh the invite so any breakage self-heals. 0 = off.
DISCORD_INVITE_REFRESH_HOURS=6

# Port for the redirect server. Cloud hosts set this automatically — leave blank.
PORT=

# --- Daily "question of the day" posts ------------------------------------
# Channel the daily post lands in. Falls back to DISCORD_CHANNEL_ID if blank.
DISCORD_DAILY_CHANNEL_ID=
# Time of day to post, 24h HH:MM, in the timezone below.
DISCORD_DAILY_TIME=09:00
# Timezone for the daily post time.
DISCORD_DAILY_TZ=America/Los_Angeles

# Optional: a channel webhook URL. If set, `blast` can post via the webhook
# instead of the bot (no bot token needed for plain announcements).
# Channel Settings > Integrations > Webhooks > New Webhook > Copy URL.
DISCORD_WEBHOOK_URL=

# Optional: default display name/avatar used when posting via webhook.
DISCORD_WEBHOOK_NAME=Single Besties

# Optional: channel where the bot greets new members. Leave blank to disable.
DISCORD_WELCOME_CHANNEL_ID=

# Optional: welcome text. {user} is replaced with an @mention of the new member.
DISCORD_WELCOME_MESSAGE=welcome to single besties, {user} 💌 you're officially in the group chat — pull up a chair and introduce yourself, bestie ✨
